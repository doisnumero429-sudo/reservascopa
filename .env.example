# SUPABASE — obrigatórias
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=COLE_A_CHAVE_SECRETA_SERVICE_ROLE
SUPABASE_PUBLISHABLE_KEY=COLE_A_CHAVE_PUBLICA_PUBLISHABLE_OU_ANON

# PIX — obrigatória (chave Pix do recebedor, NUNCA exposta ao navegador)
# Formatos aceitos: telefone com DDI (+5518981300251), CPF, CNPJ, e-mail ou chave aleatória
PIX_KEY=+55XXXXXXXXXXX

# OPENROUTER — obrigatória para respostas com IA
OPENROUTER_API_KEY=COLE_A_CHAVE_DA_OPENROUTER

# OPENROUTER — recomendadas
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_SITE_URL=https://SEU-DOMINIO.vercel.app
OPENROUTER_APP_NAME=Araçá Grill - Reservas da Copa
